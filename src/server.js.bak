async function boot() {
  await ensureQuestionsTableAndDefaults();
  app.listen(PORT, function () {
    console.log('Server running at ' + BASE_URL);
  });
}

boot().catch((e) => {
  console.error('Boot failed:', e);
  process.exit(1);
});
